rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user is admin (supports Firebase custom claims or email fallback)
    // To add admin via custom claims: Firebase Console > Auth > Users > Custom Claims > { "admin": true }
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'nitesh4learning@gmail.com'
      );
    }

    // Content (posts) — anyone can read, authenticated users can create/update
    // Note: saveContent() uses setDoc with merge:true (upsert) for all posts
    match /content/{postId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Articles — anyone can read, authenticated users can create/update
    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Forge sessions — anyone can read, authenticated users can create/update
    match /forge_sessions/{sessionId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Config (themes, agents) — anyone can read, admin-only write
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects config — anyone can read, authenticated users can write
    // (separated so user projects persist across browsers via Firestore)
    match /config/projects {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // User profiles — users can read/write their own, admin can read all
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Orchestration runs — anyone can read, authenticated users can create/update
    match /orchestration_runs/{runId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Counters (visit tracking, etc.) — anyone can read, authenticated users can update
    match /counters/{counterId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Cycles collection (future) — anyone can read, admin can write
    match /cycles/{cycleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
