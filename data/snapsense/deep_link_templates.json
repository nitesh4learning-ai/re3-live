{
  "version": "1.0.0",
  "description": "SnapSense deep link templates for ACT stage - maps actions to external apps/URLs",
  "last_updated": "2026-03-07",
  "templates": {
    "product_buy": {
      "label": "Buy",
      "icon": "shopping_cart",
      "providers": [
        {
          "name": "Amazon",
          "scheme": "amazon://search?q={product_name}",
          "fallback_url": "https://www.amazon.com/s?k={product_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 1
        },
        {
          "name": "Walmart",
          "scheme": "walmart://search?query={product_name}",
          "fallback_url": "https://www.walmart.com/search?q={product_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 2
        },
        {
          "name": "Target",
          "scheme": "target://search?q={product_name}",
          "fallback_url": "https://www.target.com/s?searchTerm={product_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 3
        },
        {
          "name": "Instacart",
          "scheme": "instacart://search?q={product_name}",
          "fallback_url": "https://www.instacart.com/store/search/{product_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 4
        }
      ]
    },
    "product_buy_alternative": {
      "label": "Buy Healthier Alternative",
      "icon": "swap_horiz",
      "providers": [
        {
          "name": "Amazon",
          "scheme": "amazon://search?q={alternative_name}",
          "fallback_url": "https://www.amazon.com/s?k={alternative_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 1
        },
        {
          "name": "Thrive Market",
          "scheme": "thrivemarket://search?q={alternative_name}",
          "fallback_url": "https://thrivemarket.com/search?search={alternative_name_encoded}",
          "platform": ["ios", "android"],
          "priority": 2
        }
      ]
    },
    "product_learn_more": {
      "label": "Learn More",
      "icon": "info",
      "providers": [
        {
          "name": "Open Food Facts",
          "url": "https://world.openfoodfacts.org/product/{barcode}",
          "condition": "has_barcode",
          "priority": 1
        },
        {
          "name": "Google Search",
          "url": "https://www.google.com/search?q={product_name_encoded}+nutrition+facts",
          "priority": 2
        }
      ]
    },
    "food_recipe": {
      "label": "Find Recipes",
      "icon": "restaurant_menu",
      "providers": [
        {
          "name": "AllRecipes",
          "url": "https://www.allrecipes.com/search?q={food_name_encoded}",
          "priority": 1
        },
        {
          "name": "YouTube",
          "scheme": "youtube://results?search_query={food_name_encoded}+recipe",
          "fallback_url": "https://www.youtube.com/results?search_query={food_name_encoded}+recipe",
          "priority": 2
        }
      ]
    },
    "animal_adopt": {
      "label": "Adopt",
      "icon": "pets",
      "providers": [
        {
          "name": "Petfinder",
          "url": "https://www.petfinder.com/search/dogs-for-adoption/?breed={breed_name_encoded}",
          "condition": "is_dog",
          "priority": 1
        },
        {
          "name": "Petfinder Cats",
          "url": "https://www.petfinder.com/search/cats-for-adoption/?breed={breed_name_encoded}",
          "condition": "is_cat",
          "priority": 1
        },
        {
          "name": "ASPCA",
          "url": "https://www.aspca.org/adopt-pet",
          "priority": 2
        }
      ]
    },
    "animal_vet": {
      "label": "Find a Vet",
      "icon": "local_hospital",
      "providers": [
        {
          "name": "Google Maps",
          "scheme": "comgooglemaps://?q=veterinarian+near+me",
          "fallback_url": "https://www.google.com/maps/search/veterinarian+near+me",
          "platform": ["ios", "android"],
          "priority": 1
        },
        {
          "name": "Yelp",
          "scheme": "yelp:///search?terms=veterinarian",
          "fallback_url": "https://www.yelp.com/search?find_desc=veterinarian",
          "priority": 2
        }
      ]
    },
    "animal_care_guide": {
      "label": "Care Guide",
      "icon": "menu_book",
      "providers": [
        {
          "name": "AKC",
          "url": "https://www.akc.org/dog-breeds/{breed_slug}/",
          "condition": "is_dog",
          "priority": 1
        },
        {
          "name": "CFA",
          "url": "https://cfa.org/breeds/",
          "condition": "is_cat",
          "priority": 1
        },
        {
          "name": "Google Search",
          "url": "https://www.google.com/search?q={animal_name_encoded}+care+guide",
          "priority": 2
        }
      ]
    },
    "animal_report_wildlife": {
      "label": "Report Sighting",
      "icon": "report",
      "providers": [
        {
          "name": "iNaturalist",
          "scheme": "inaturalist://observations/new",
          "fallback_url": "https://www.inaturalist.org/observations/upload",
          "priority": 1
        },
        {
          "name": "Animal Control",
          "action": "phone_call",
          "number": "311",
          "condition": "is_dangerous",
          "priority": 0
        }
      ]
    },
    "plant_identify": {
      "label": "Full Identification",
      "icon": "eco",
      "providers": [
        {
          "name": "PlantNet",
          "url": "https://identify.plantnet.org/",
          "priority": 1
        },
        {
          "name": "Google Lens",
          "scheme": "googleapp://lens",
          "priority": 2
        }
      ]
    },
    "plant_buy": {
      "label": "Buy This Plant",
      "icon": "local_florist",
      "providers": [
        {
          "name": "Amazon",
          "scheme": "amazon://search?q={plant_name_encoded}+live+plant",
          "fallback_url": "https://www.amazon.com/s?k={plant_name_encoded}+live+plant",
          "priority": 1
        },
        {
          "name": "Etsy",
          "url": "https://www.etsy.com/search?q={plant_name_encoded}+plant",
          "priority": 2
        },
        {
          "name": "Home Depot",
          "url": "https://www.homedepot.com/s/{plant_name_encoded}",
          "priority": 3
        }
      ]
    },
    "plant_toxicity_info": {
      "label": "Toxicity Details",
      "icon": "warning",
      "color": "#D32F2F",
      "providers": [
        {
          "name": "ASPCA Poison Control",
          "url": "https://www.aspca.org/pet-care/animal-poison-control/toxic-and-non-toxic-plants",
          "condition": "has_pets",
          "priority": 1
        },
        {
          "name": "Poison Control",
          "action": "phone_call",
          "number": "1-800-222-1222",
          "condition": "is_emergency",
          "priority": 0
        }
      ]
    },
    "household_buy_again": {
      "label": "Reorder",
      "icon": "replay",
      "providers": [
        {
          "name": "Amazon",
          "scheme": "amazon://search?q={product_name_encoded}",
          "fallback_url": "https://www.amazon.com/s?k={product_name_encoded}",
          "priority": 1
        }
      ]
    },
    "household_manual": {
      "label": "Product Manual",
      "icon": "description",
      "providers": [
        {
          "name": "ManualsLib",
          "url": "https://www.manualslib.com/manual/search/{product_name_encoded}/",
          "condition": "is_electronics",
          "priority": 1
        },
        {
          "name": "Google Search",
          "url": "https://www.google.com/search?q={product_name_encoded}+manual+pdf",
          "priority": 2
        }
      ]
    },
    "household_recycle": {
      "label": "How to Recycle",
      "icon": "recycling",
      "providers": [
        {
          "name": "Earth911",
          "url": "https://search.earth911.com/?what={product_name_encoded}",
          "priority": 1
        },
        {
          "name": "Google Search",
          "url": "https://www.google.com/search?q=how+to+recycle+{product_name_encoded}",
          "priority": 2
        }
      ]
    },
    "medication_info": {
      "label": "Drug Information",
      "icon": "medication",
      "providers": [
        {
          "name": "WebMD",
          "url": "https://www.webmd.com/drugs/2/search?query={medication_name_encoded}",
          "priority": 1
        },
        {
          "name": "Drugs.com",
          "url": "https://www.drugs.com/search.php?searchterm={medication_name_encoded}",
          "priority": 2
        }
      ],
      "disclaimer": "This information is not medical advice. Consult your healthcare provider."
    },
    "medication_interaction_check": {
      "label": "Check Interactions",
      "icon": "compare_arrows",
      "providers": [
        {
          "name": "Drugs.com Interaction Checker",
          "url": "https://www.drugs.com/drug_interactions.html",
          "priority": 1
        }
      ],
      "disclaimer": "Always consult your pharmacist or doctor about drug interactions."
    },
    "emergency_poison_control": {
      "label": "Poison Control",
      "icon": "emergency",
      "color": "#D32F2F",
      "providers": [
        {
          "name": "Poison Control Hotline",
          "action": "phone_call",
          "number": "1-800-222-1222",
          "priority": 0
        },
        {
          "name": "Emergency Services",
          "action": "phone_call",
          "number": "911",
          "condition": "is_life_threatening",
          "priority": 0
        }
      ]
    },
    "share_scan": {
      "label": "Share",
      "icon": "share",
      "providers": [
        {
          "name": "Native Share",
          "action": "system_share",
          "content": "I scanned {item_name} with SnapSense! Health score: {health_score}/100",
          "priority": 1
        }
      ]
    },
    "save_to_history": {
      "label": "Save to History",
      "icon": "bookmark",
      "providers": [
        {
          "name": "Local Storage",
          "action": "save_local",
          "collection": "scan_history",
          "priority": 1
        }
      ]
    }
  },
  "link_resolution": {
    "check_app_installed": true,
    "fallback_to_browser": true,
    "track_clicks": true,
    "open_in_app_browser": false
  }
}
