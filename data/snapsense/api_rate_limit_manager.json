{
  "version": "1.0.0",
  "description": "API rate limit management with fallback strategies for SnapSense. Manages free-tier API quotas across providers and implements graceful degradation.",
  "last_updated": "2026-03-07",
  "providers": {
    "open_food_facts": {
      "tier": "free",
      "rate_limit": {
        "requests_per_minute": 100,
        "requests_per_day": null,
        "note": "No hard daily limit but be respectful. Rate limit to 100/min."
      },
      "base_url": "https://world.openfoodfacts.org/api/v2",
      "endpoints": {
        "product": "/product/{barcode}",
        "search": "/search?search_terms={query}&page_size=5"
      },
      "timeout_ms": 5000,
      "priority": 1,
      "fallback": "local_cache",
      "health_check_url": "https://world.openfoodfacts.org/api/v2/product/3017620422003",
      "status": "active"
    },
    "plantnet": {
      "tier": "free",
      "rate_limit": {
        "requests_per_day": 500,
        "requests_per_minute": 10,
        "note": "500/day free. Premium: 10,000/day at €50/month"
      },
      "base_url": "https://my-api.plantnet.org/v2",
      "endpoints": {
        "identify": "/identify/all?api-key={api_key}"
      },
      "timeout_ms": 8000,
      "priority": 1,
      "fallback": "local_toxic_plants_db",
      "daily_budget_strategy": {
        "morning_reserve_pct": 40,
        "afternoon_reserve_pct": 35,
        "evening_reserve_pct": 25,
        "timezone": "America/New_York"
      },
      "status": "active"
    },
    "upcitemdb": {
      "tier": "free",
      "rate_limit": {
        "requests_per_day": 100,
        "requests_per_minute": 6,
        "note": "100/day free. Exhausts fast. Use only as last resort after OFF."
      },
      "base_url": "https://api.upcitemdb.com/prod/trial",
      "endpoints": {
        "lookup": "/lookup?upc={barcode}"
      },
      "timeout_ms": 5000,
      "priority": 3,
      "fallback": "claude_haiku",
      "status": "reserve_only"
    },
    "nutritionix": {
      "tier": "free",
      "rate_limit": {
        "requests_per_day": 200,
        "requests_per_minute": 5,
        "note": "200/day with free tier. Need app_id and api_key."
      },
      "base_url": "https://trackapi.nutritionix.com/v2",
      "endpoints": {
        "natural_nutrients": "/natural/nutrients",
        "search_instant": "/search/instant?query={query}"
      },
      "timeout_ms": 5000,
      "priority": 2,
      "fallback": "open_food_facts",
      "daily_budget_strategy": {
        "morning_reserve_pct": 35,
        "afternoon_reserve_pct": 40,
        "evening_reserve_pct": 25,
        "timezone": "America/New_York"
      },
      "status": "active"
    },
    "edamam": {
      "tier": "free",
      "rate_limit": {
        "requests_per_day": 200,
        "requests_per_minute": 10,
        "note": "200/day free (Food Database API). Separate limits for Recipe and Nutrition Analysis."
      },
      "base_url": "https://api.edamam.com/api",
      "endpoints": {
        "food_database": "/food-database/v2/parser?ingr={query}&app_id={app_id}&app_key={api_key}"
      },
      "timeout_ms": 5000,
      "priority": 2,
      "fallback": "open_food_facts",
      "status": "active"
    },
    "usda_fdc": {
      "tier": "free",
      "rate_limit": {
        "requests_per_hour": 1000,
        "requests_per_day": null,
        "note": "1000/hour with API key. Generous free tier."
      },
      "base_url": "https://api.nal.usda.gov/fdc/v1",
      "endpoints": {
        "search": "/foods/search?query={query}&api_key={api_key}",
        "food": "/food/{fdc_id}?api_key={api_key}"
      },
      "timeout_ms": 5000,
      "priority": 1,
      "fallback": "nutritionix",
      "status": "active"
    },
    "claude_haiku": {
      "tier": "paid",
      "rate_limit": {
        "requests_per_minute": 60,
        "daily_budget_usd": 2.00,
        "cost_per_call_usd": 0.0002
      },
      "model": "claude-haiku-4-5-20251001",
      "timeout_ms": 3000,
      "priority": 99,
      "role": "universal_fallback",
      "use_cases": [
        "label_translation_fallback",
        "unknown_item_identification",
        "dietary_recommendation",
        "when_all_free_apis_exhausted"
      ],
      "status": "active"
    }
  },
  "fallback_chain": {
    "barcode_lookup": [
      { "step": 1, "provider": "local_cache", "collection": "products", "cost": 0 },
      { "step": 2, "provider": "open_food_facts", "cost": 0 },
      { "step": 3, "provider": "upcitemdb", "cost": 0, "condition": "off_miss" },
      { "step": 4, "provider": "claude_haiku", "cost": 0.0002, "condition": "all_apis_miss" }
    ],
    "food_nutrition": [
      { "step": 1, "provider": "local_cache", "collection": "common_foods", "cost": 0 },
      { "step": 2, "provider": "usda_fdc", "cost": 0 },
      { "step": 3, "provider": "nutritionix", "cost": 0, "condition": "usda_miss" },
      { "step": 4, "provider": "edamam", "cost": 0, "condition": "nutritionix_miss" },
      { "step": 5, "provider": "open_food_facts", "cost": 0, "condition": "edamam_miss" },
      { "step": 6, "provider": "claude_haiku", "cost": 0.0002, "condition": "all_miss" }
    ],
    "plant_identification": [
      { "step": 1, "provider": "local_cache", "collection": "toxic_plants", "cost": 0 },
      { "step": 2, "provider": "plantnet", "cost": 0 },
      { "step": 3, "provider": "claude_haiku", "cost": 0.0002, "condition": "plantnet_exhausted" }
    ],
    "animal_identification": [
      { "step": 1, "provider": "local_cache", "collection": "dog_breeds,cat_breeds", "cost": 0 },
      { "step": 2, "provider": "claude_haiku", "cost": 0.0002, "condition": "breed_not_in_db" }
    ]
  },
  "quota_management": {
    "tracking": {
      "storage": "device_local",
      "key_format": "snapsense_quota_{provider}_{date}",
      "reset_time": "00:00 UTC"
    },
    "budget_distribution": {
      "strategy": "time_weighted",
      "description": "Reserve API calls proportionally across day to avoid exhausting budget by noon",
      "time_windows": [
        { "hours": "00:00-06:00", "budget_pct": 5, "label": "overnight" },
        { "hours": "06:00-10:00", "budget_pct": 20, "label": "morning" },
        { "hours": "10:00-14:00", "budget_pct": 30, "label": "midday" },
        { "hours": "14:00-18:00", "budget_pct": 25, "label": "afternoon" },
        { "hours": "18:00-22:00", "budget_pct": 15, "label": "evening" },
        { "hours": "22:00-00:00", "budget_pct": 5, "label": "night" }
      ]
    },
    "exhaustion_behavior": {
      "when_provider_exhausted": [
        "log_exhaustion_event",
        "switch_to_next_in_fallback_chain",
        "show_user_notice_if_degraded",
        "queue_for_next_day_if_non_urgent"
      ],
      "when_all_free_exhausted": [
        "use_claude_haiku_within_daily_budget",
        "use_local_cache_only_if_budget_exceeded",
        "show_degraded_mode_banner"
      ],
      "degraded_mode_ui": {
        "banner_text": "Some features are limited today. Results may be less detailed.",
        "banner_color": "#FFA726",
        "features_disabled": ["real_time_nutrition_lookup", "plant_api_identification"],
        "features_available": ["barcode_local_cache", "breed_local_cache", "toxic_plants_local_cache", "health_score_local"]
      }
    }
  },
  "monitoring": {
    "track_metrics": [
      "api_calls_per_provider_per_day",
      "cache_hit_rate",
      "fallback_trigger_count",
      "average_response_time_ms",
      "error_rate_per_provider",
      "daily_llm_spend_usd"
    ],
    "alert_thresholds": {
      "daily_budget_75pct": "warn",
      "daily_budget_90pct": "critical",
      "error_rate_above_10pct": "warn",
      "response_time_above_5s": "warn"
    },
    "reporting": {
      "daily_summary": true,
      "storage": "firestore_collection_analytics"
    }
  },
  "scaling_plan": {
    "at_1k_users": {
      "estimated_daily_scans": 5000,
      "action": "Open Food Facts handles load. Monitor PlantNet/Nutritionix quotas.",
      "monthly_cost": "$0-5 (Claude Haiku fallback only)"
    },
    "at_10k_users": {
      "estimated_daily_scans": 50000,
      "action": "Upgrade PlantNet to premium ($50/mo). Add Nutritionix paid tier ($0/extra with caching). Pre-seed Firestore heavily.",
      "monthly_cost": "$50-100"
    },
    "at_100k_users": {
      "estimated_daily_scans": 500000,
      "action": "Self-hosted ML model for plant ID. Full product DB mirror from Open Food Facts dump. Nutritionix Enterprise.",
      "monthly_cost": "$500-1000"
    }
  }
}
