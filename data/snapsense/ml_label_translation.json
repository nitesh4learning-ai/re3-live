{
  "version": "1.0.0",
  "description": "ML Kit label → API search term translation layer. Bridges generic ML Kit labels to specific API query terms for USDA, Nutritionix, Open Food Facts, PlantNet, etc.",
  "last_updated": "2026-03-07",
  "strategy": {
    "priority_order": [
      "exact_match",
      "label_map",
      "compound_label_merge",
      "claude_haiku_refine"
    ],
    "claude_haiku_cost_per_call": 0.0002,
    "claude_haiku_timeout_ms": 2000,
    "cache_translations": true,
    "cache_ttl_hours": 720
  },
  "food_labels": {
    "chocolate": {
      "api_terms": {
        "usda": "chocolate bar dark",
        "nutritionix": "chocolate bar",
        "open_food_facts": "chocolate"
      },
      "modifiers": {
        "dark": { "usda": "dark chocolate bar 70% cocoa", "nutritionix": "dark chocolate" },
        "milk": { "usda": "milk chocolate bar", "nutritionix": "milk chocolate" },
        "white": { "usda": "white chocolate bar", "nutritionix": "white chocolate" },
        "wrapper": { "use_barcode": true }
      }
    },
    "bread": {
      "api_terms": {
        "usda": "bread white enriched",
        "nutritionix": "white bread slice",
        "open_food_facts": "bread"
