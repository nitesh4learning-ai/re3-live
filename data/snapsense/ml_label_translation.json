  "animal_labels": {
    "dog": {
      "search_terms": {
        "akc": "{breed_name}",
        "google": "{breed_name} dog breed care guide"
      },
      "breed_detection_flow": "ml_label → dog_breeds.json lookup → breed card"
    },
    "cat": {
      "search_terms": {
        "cfa": "{breed_name}",
        "google": "{breed_name} cat breed care guide"
      },
      "breed_detection_flow": "ml_label → cat_breeds.json lookup → breed card"
    },
    "bird": {
      "search_terms": {
        "audubon": "{species_name}",
        "google": "{species_name} bird identification"
      }
    },
    "snake": {
      "search_terms": {
        "google": "{label} snake identification venomous"
      },
      "always_warn": true,
      "warning": "Do not approach. Some snakes are venomous."
    },
    "spider": {
      "search_terms": {
        "google": "{label} spider identification dangerous"
      },
      "always_warn": true,
      "warning": "Do not touch. Some spiders have medically significant bites."
    }
  },
  "plant_labels": {
    "_default": {
      "search_terms": {
        "plantnet": "{label}",
        "google": "{label} plant identification"
      },
      "toxicity_check_flow": "ml_label → toxic_plants.json lookup → toxicity card"
    },
    "flower": {
      "search_terms": {
        "plantnet": "{label} flower",
        "google": "{label} flower identification care"
      }
    },
    "mushroom": {
      "search_terms": {
        "google": "{label} mushroom identification edible poisonous"
      },
      "always_warn": true,
      "warning": "Never eat wild mushrooms without expert identification. Many deadly mushrooms resemble edible ones."
    },
    "tree": {
      "search_terms": {
        "plantnet": "{label} tree",
        "google": "{label} tree identification"
      }
    }
  },
  "compound_label_rules": {
    "description": "When ML Kit returns multiple labels for the same object, merge them into a more specific search term",
    "rules": [
      { "labels": ["food", "chocolate", "dark"], "merged_term": "dark chocolate bar" },
      { "labels": ["food", "chocolate", "bar"], "merged_term": "chocolate candy bar" },
      { "labels": ["food", "bread", "toast"], "merged_term": "toasted bread" },
      { "labels": ["food", "cake", "chocolate"], "merged_term": "chocolate cake" },
      { "labels": ["food", "soup", "bowl"], "merged_term": "bowl of soup" },
      { "labels": ["drink", "bottle", "water"], "merged_term": "bottled water" },
      { "labels": ["drink", "coffee", "cup"], "merged_term": "cup of coffee" },
      { "labels": ["drink", "juice", "orange"], "merged_term": "orange juice" },
      { "labels": ["animal", "dog", "puppy"], "merged_term": "puppy" },
      { "labels": ["plant", "flower", "rose"], "merged_term": "rose flower" },
      { "labels": ["plant", "cactus", "succulent"], "merged_term": "cactus succulent" },
      { "labels": ["food", "meat", "raw"], "merged_term": "raw meat" },
      { "labels": ["food", "vegetable", "green"], "merged_term": "green vegetables" },
      { "labels": ["food", "fruit", "berry"], "merged_term": "mixed berries" },
      { "labels": ["food", "noodle", "soup"], "merged_term": "noodle soup" },
      { "labels": ["food", "sushi", "rice"], "merged_term": "sushi roll" },
      { "labels": ["food", "taco", "meat"], "merged_term": "beef taco" },
      { "labels": ["food", "burrito", "wrap"], "merged_term": "burrito" },
      { "labels": ["food", "donut", "pastry"], "merged_term": "donut" },
      { "labels": ["food", "muffin", "baked"], "merged_term": "muffin" }
    ]
  },
  "claude_haiku_fallback": {
    "description": "When label_map and compound rules fail, send labels to Claude Haiku for term refinement",
    "enabled": true,
    "model": "claude-haiku-4-5-20251001",
    "max_input_tokens": 100,
    "max_output_tokens": 50,
    "estimated_cost_per_call": 0.0002,
    "daily_budget_cap": 1.00,
    "prompt_template": "You are a food/product identification assistant. Given these ML Kit labels: [{labels}] and confidence scores: [{scores}], return ONLY a specific search term for a nutrition API. Be specific (e.g., 'dark chocolate bar 70% cocoa' not 'chocolate'). Return just the search term, nothing else.",
    "cache_results": true,
    "cache_key_format": "haiku_translate_{sorted_labels_hash}"
  }
}
