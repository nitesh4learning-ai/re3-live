{
  "version": "1.0.0",
  "description": "Firestore product collection seeder strategy. Solves the cold-start problem: day 1 with zero users = zero cache = every scan hits external APIs.",
  "last_updated": "2026-03-07",
  "problem": {
    "description": "The flywheel (user scans → cache grows → fewer API calls) requires initial momentum. Without pre-seeding, the first 1,000 users will exhaust free API quotas immediately.",
    "impact": "PlantNet (500/day), UPCitemdb (100/day), Nutritionix (200/day) exhausted within hours of launch."
  },
  "solution": "Pre-seed Firestore products collection from Open Food Facts bulk data dump + curated common items",
  "data_sources": [
    {
      "name": "Open Food Facts MongoDB Dump",
      "url": "https://world.openfoodfacts.org/data",
      "format": "JSONL (gzipped)",
      "size": "~7GB compressed, ~35GB uncompressed",
      "total_products": 3000000,
      "update_frequency": "daily",
      "license": "Open Database License (ODbL)",
      "fields_to_extract": [
        "code (barcode)",
        "product_name",
        "brands",
        "categories_tags",
        "nutriments",
        "allergens_tags",
        "nova_group",
        "ecoscore_grade",
        "nutriscore_grade",
        "image_url",
        "ingredients_text",
        "countries_tags"
      ]
    },
    {
      "name": "USDA FoodData Central",
      "url": "https://fdc.nal.usda.gov/download-datasets.html",
      "format": "CSV",
      "total_items": 400000,
      "license": "Public Domain",
      "use_for": "Nutritional data enrichment for unpackaged foods"
    },
    {
      "name": "SnapSense Product Cache Seed (bundled)",
      "path": "data/snapsense/product_cache_seed.json",
      "total_items": 2000,
      "use_for": "Day-0 bootstrap, always available offline"
    }
  ],
  "seeding_strategy": {
    "phase_1_bundled": {
      "timing": "app build time",
      "source": "product_cache_seed.json (bundled in app)",
      "count": 2000,
      "criteria": "Top 2000 most-scanned products in US grocery stores",
      "storage": "Hive local DB on device",
      "cost": 0,
      "offline_available": true
    },
    "phase_2_firestore_seed": {
      "timing": "one-time server script before launch",
      "source": "Open Food Facts bulk dump (filtered)",
      "count": 100000,
      "criteria": {
        "countries": ["en:united-states", "en:united-kingdom", "en:canada", "en:australia"],
        "completeness": "product_name AND nutriments.energy_value present",
        "has_barcode": true,
        "not_obsolete": true
      },
      "storage": "Firestore 'products' collection",
      "document_schema": {
        "barcode": "string (document ID)",
        "name": "string",
        "brand": "string",
        "category": "string",
        "health_score": "number (0-100, computed)",
        "nutrition": {
          "calories": "number",
          "fat_g": "number",
          "saturated_fat_g": "number",
          "carbs_g": "number",
          "sugar_g": "number",
          "fiber_g": "number",
          "protein_g": "number",
          "sodium_mg": "number",
          "salt_g": "number"
        },
        "allergens": ["string"],
        "nova_group": "number (1-4)",
        "nutri_score": "string (A-E)",
        "eco_score": "string (A-E)",
        "ingredients_flag": ["string"],
        "alternatives": ["string"],
        "image_url": "string",
        "source": "string (off | usda | user_scan)",
        "last_updated": "timestamp",
        "scan_count": "number (starts at 0)"
      },
      "estimated_firestore_cost": {
        "writes": "$0.18 per 100K documents × 1 = $0.18",
        "storage": "~200MB at $0.18/GB/month = $0.04/month",
        "reads": "depends on usage"
      }
    },
    "phase_3_user_flywheel": {
      "timing": "ongoing after launch",
      "trigger": "user scans a barcode not in Firestore cache",
      "flow": [
        "1. Check Firestore cache (products/{barcode})",
        "2. Cache miss → call Open Food Facts API",
        "3. If found → compute health_score → write to Firestore cache",
        "4. If not found → try UPCitemdb → write to cache",
        "5. If still not found → Claude Haiku identifies → write to cache",
        "6. Increment scan_count on cached products"
      ],
      "dedup": "Firestore document ID = barcode (natural dedup)",
      "staleness": {
        "max_age_days": 90,
        "refresh_trigger": "scan_count > 100 AND last_updated > 90 days ago"
      }
    }
  },
  "health_score_computation": {
    "description": "Compute a 0-100 health score from nutritional data. Higher = healthier.",
    "algorithm": "weighted_nutrient_scoring",
    "positive_factors": [
      { "nutrient": "fiber_g", "weight": 10, "per_serving": true },
      { "nutrient": "protein_g", "weight": 8, "per_serving": true },
      { "nutrient": "fruits_vegetables_pct", "weight": 5 }
    ],
    "negative_factors": [
      { "nutrient": "sugar_g", "weight": -12, "threshold": 10 },
      { "nutrient": "saturated_fat_g", "weight": -10, "threshold": 5 },
      { "nutrient": "sodium_mg", "weight": -8, "threshold": 600 },
      { "nutrient": "calories", "weight": -5, "threshold": 300 }
    ],
    "nova_penalty": {
      "1": 0,
      "2": -5,
      "3": -10,
      "4": -20
    },
    "base_score": 50,
    "min_score": 0,
    "max_score": 100,
    "fallback_if_missing_data": 50
  },
  "seeder_script": {
    "description": "Node.js script to run the Phase 2 seeding",
    "estimated_runtime": "30-60 minutes for 100K products",
    "batch_size": 500,
    "firestore_batch_write": true,
    "error_handling": "skip_malformed_and_log",
    "resume_support": true,
    "resume_key": "last_processed_line_number"
  },
  "maintenance": {
    "weekly_refresh": {
      "description": "Weekly cron job to refresh top-scanned products from Open Food Facts",
      "target": "products with scan_count > 50",
      "batch_size": 1000,
      "day": "Sunday",
      "time": "03:00 UTC"
    },
    "monthly_bulk_update": {
      "description": "Monthly re-import of Open Food Facts delta dump",
      "source": "https://world.openfoodfacts.org/data/delta/",
      "format": "JSONL",
      "estimated_size": "50-100MB"
    }
  }
}
